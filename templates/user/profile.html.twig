{% extends 'base.html.twig' %}

{% block title %}Profil de {{ user.username }}{% endblock %}

{% block body %}

    <section class="section bg-gray">
        <div class="container">
            <div class="card card-elevated">

                <!-- Header -->
                <div class="card-header flex justify-between items-center">
                    <div>
                        <h2 class="card-title mb-sm">
                            {{ user.prenom ?? '' }} {{ user.nom ?? '' }}
                        </h2>
                        <p class="text-primary">@{{ user.username }}</p>
                    </div>

                    {% if app.user and app.user.id == user.id %}
                        <a href="{{ path('user_profile_edit', {id: user.id}) }}"
                           class="btn btn-outline btn-sm">
                            Modifier
                        </a>
                    {% endif %}
                </div>

                <!-- Body -->
                <div class="card-body">
                    <div class="flex flex-col gap-md">
                        <!-- Username -->
                        <div>
                            <h4>Username</h4>
                            <p class="card-text">{{ user.username }}</p>
                        </div>

                        <!-- Email -->
                        <div>
                            <h4>Email</h4>
                            <p class="card-text">{{ user.email }}</p>
                        </div>

                        {% for role in user.roles %}
                            {% if role == 'ROLE_CUSTOMER' %}
                                <!-- Nom -->
                                <div>
                                    <h4>Nom</h4>
                                    <p class="card-text">
                                        {{ user.nom ?? 'Non renseigné' }}
                                    </p>
                                </div>

                                <!-- Prénom -->
                                <div>
                                    <h4>Prénom</h4>
                                    <p class="card-text">
                                        {{ user.prenom ?? 'Non renseigné' }}
                                    </p>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>

                <!-- Reservation -->
                <div class="card-header flex justify-between items-center">
                    <h2 class="card-title mb-sm">
                        Vos réservations
                    </h2>
                </div>
                <div class="card-body">
                    {% if user.reservations|length > 0 %}
                        <div class="bookings-table">
                            {% for reservation in user.reservations %}
                                <div class="booking-item">
                                    <!-- Offre + Infos -->
                                    <div class="booking-info">
                                        <h4>{{ reservation.offre.label }}</h4>
                                        <span class="booking-location">
                                            {{ reservation.units|length }} unité(s) réservée(s)
                                        </span>
                                    </div>

                                    <!-- Dates -->
                                    <div class="booking-dates">
                                        <span class="booking-date">
                                            {{ reservation.dateDeb|date('d/m/Y') }}
                                        </span>
                                        <span class="booking-time">
                                            au {{ reservation.dateFin|date('d/m/Y') }}
                                        </span>
                                    </div>
                                    <!-- Badge statut -->
                                    <div class="flex items-center gap-sm">
                                        {% if reservation.dateFin > "now"|date %}
                                            <span class="badge badge-success-soft badge-pill">
                                                Active
                                            </span>
                                        {% else %}
                                            <span class="badge badge-gray-soft badge-pill">
                                                Terminée
                                            </span>
                                        {% endif %}

                                        <a href="{{ path('reservation_manage', {id: reservation.id}) }}"
                                           class="btn btn-outline btn-sm">
                                            Voir
                                        </a>

                                        <a href="{{ path('reservation_interventions', {id: reservation.id}) }}"
                                           class="btn btn-outline btn-sm">
                                            Interventions
                                        </a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="text-center p-md">
                            <p class="card-text">Vous n'avez aucune réservation.</p>
                        </div>
                    {% endif %}
                </div>

            </div>
        </div>
    </section>

{% endblock %}
