{% extends 'base.html.twig' %}

{% block title %}Accueil - Work Together{% endblock %}

{% block body %}

    <!-- HERO -->
    <section class="hero text-center">
        <div class="container hero-content">
            <h1 class="hero-title mb-md">
                Bienvenue sur <span class="highlight">Work Together</span>
            </h1>
        </div>
    </section>

    <!-- QUI SOMMES-NOUS -->
    <section class="features text-center">
        <div class="container">
            <h2 class="section-title mb-md">Qui sommes-nous ?</h2>

            <p class="section-description mb-lg">
                WorkTogether Data Solutions est une entreprise spécialisée dans la gestion de datacenters de
                pointe. Forte de son expertise en matière de sécurité, de fiabilité et de durabilité, WorkTogether
                offre une gamme complète de services de gestion de datacenters aux entreprises du monde
                entier.
            </p>
        </div>
    </section>

    <!-- NOS OFFRES -->
    <section class="popular-venues bg-gray">
        <div class="container">

            <div class="text-center mb-xl">
                <h2 class="section-title mb-sm">Nos offres</h2>
            </div>

            <div class="flex gap-xl justify-between flex-wrap">

                <!-- FILTRE DURÉE -->
                <div class="filter-group">
                    <label for="duration">Durée de la location (mois) :</label>
                    <select id="duration" class="filter-select">
                        <option selected disabled>Choisissez une durée</option>
                        <option value="1">1 mois</option>
                        <option value="12">12 mois (-10% supplémentaires)</option>
                    </select>
                </div>

                <!-- CARDS OFFRES -->
                <div class="flex gap-lg flex-wrap justify-center w-full">
                    {% for offre in offres %}
                        {% include 'offre/_card.html.twig' with {'offre': offre} only %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>

{% endblock %}
