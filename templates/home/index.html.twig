{% extends 'base.html.twig' %}

{% block body %}

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <div class="hero-content text-center">
                <h1 class="hero-title mb-md">
                    <span class="highlight">WorkTogether</span>
                </h1>
                <p class="hero-description mb-xl">
                    WorkTogether Data Solutions est une entreprise spécialisée dans la gestion de datacenters de
                    pointe. Forte de son expertise en matière de sécurité, de fiabilité et de durabilité, WorkTogether
                    offre une gamme complète de services de gestion de datacenters aux entreprises du monde
                    entier.
                </p>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features">
        <div class="container">
            <div class="section-header text-center mb-xl">
                <h2 class="section-title mb-sm">Pourquoi choisir SpaceHub ?</h2>
                <p class="section-description">
                    Des solutions adaptées à tous vos besoins
                </p>
            </div>
            <div class="features-grid">
                <div class="card card-flat">
                    <div class="card-body text-center">
                        <div class="feature-icon">🏢</div>
                        <h3 class="card-title">Lieux flexibles</h3>
                        <p class="card-text">Des espaces modulables qui s'adaptent à la taille et au type de votre événement.</p>
                    </div>
                </div>
                <div class="card card-flat">
                    <div class="card-body text-center">
                        <div class="feature-icon">⚡</div>
                        <h3 class="card-title">Réservation rapide</h3>
                        <p class="card-text">Système de réservation en ligne simple et efficace, disponible 24h/24.</p>
                    </div>
                </div>
                <div class="card card-flat">
                    <div class="card-body text-center">
                        <div class="feature-icon">🛡️</div>
                        <h3 class="card-title">Service premium</h3>
                        <p class="card-text">Accompagnement personnalisé et support technique pour garantir le succès de vos événements.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
