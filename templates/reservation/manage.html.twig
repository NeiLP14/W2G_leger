{% extends 'base.html.twig' %}

{% block title %}Gestion réservation{% endblock %}

{% block body %}
    <section class="section bg-gray">
        <div class="container">
            <div class="card card-elevated">
                <div class="card-header">
                    <h2 class="card-title">
                        Offre : {{ reservation.offre.label }}
                    </h2>
                    <p class="card-text">
                        Du {{ reservation.dateDeb|date('d/m/Y') }}
                        au {{ reservation.dateFin|date('d/m/Y') }}
                    </p>
                </div>

                <div class="card-body">
                    {% if reservation.units|length > 0 %}
                        <div class="bookings-table">
                            {% for unit in reservation.units %}
                                <div class="booking-item">
                                    <div class="booking-info">
                                        <h4>
                                            {{ unit.bay.label }}-{{ unit.label }}

                                            {% if unit.nomTemp %}
                                                <span class="text-muted">({{ unit.nomTemp }})</span>
                                            {% endif %}
                                        </h4>
                                    </div>
                                    <div class="flex items-center gap-sm">
                                        État :
                                        <span class="badge badge-primary-soft badge-pill">
                                            {{ unit.state.label }}
                                        </span>
                                        <button
                                            class="btn btn-sm btn-secondary"
                                            onclick="openConfigModal('{{ unit.id }}', '{{ unit.nomTemp ?? '' }}')">
                                            Configurer
                                        </button>
                                    </div>
                                </div>
                            {% endfor %}

                        </div>
                    {% else %}
                        <p class="card-text">
                            Aucune unité associée à cette réservation.
                        </p>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>
    <div id="configModal" class="modal" style="display:none;">
        <div class="modal-content">
            <h3>Configurer l'unité</h3>

            <form method="post" action="{{ path('app_unit_configure') }}">
                <input type="hidden" name="unit_id" id="modalUnitId">

                <label>Nom personnalisé</label>
                <input type="text" name="nom_temp" id="modalNomTemp" class="form-control">

                <div class="mt-2">
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                    <button type="button" class="btn btn-secondary" onclick="closeConfigModal()">Annuler</button>
                </div>
            </form>
        </div>
    </div>
    <script>
        function openConfigModal(unitId, nomTemp) {
            document.getElementById('modalUnitId').value = unitId;
            document.getElementById('modalNomTemp').value = nomTemp;
            document.getElementById('configModal').style.display = 'block';
        }

        function closeConfigModal() {
            document.getElementById('configModal').style.display = 'none';
        }
    </script>
{% endblock %}
