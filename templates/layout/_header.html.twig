<!-- Header -->
<header class="header">
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <a href="{{ path('app_home') }}">
                    <img src="{{ asset('images/logo.png') }}" alt="SpaceHub" class="logo">
                </a>
            </div>
            <ul class="nav-menu">
                <li><a href="{{ path('app_home') }}" class="nav-link active">Accueil</a></li>
            </ul>
            <div class="nav-actions">
                {% if app.user %}
                    <a href="" class="btn">{{ app.user.username}}</a>
                    <a href="{{ path('app_logout') }}" class="btn btn-outline">Déconnexion</a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn btn-outline">Connexion</a>
                    <a href="{{ path('app_register') }}" class="btn btn-primary">S'inscrire</a>
                {% endif %}
            </div>
        </div>
    </nav>
</header>
