<!-- Footer -->
<footer class="footer">
    <div class="container">
        <div class="footer-content">
            <div class="footer-section">
                <img src="{{ asset('images/logo.png') }}" alt="SpaceHub" class="footer-logo">
                <p>Des offres exceptionnels pour vos projets.</p>
            </div>
            <div class="footer-section">
                <h4>Offres</h4>
                <ul>
                    {% for offre in offres %}
                        <li><a href="{{ path('app_offre_detail', {id: offre.id}) }}">{{ offre.label }}</a></li>
                    {% endfor %}
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Work Together. Tous droits réservés.</p>
        </div>
    </div>
</footer>
